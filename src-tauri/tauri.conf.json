{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Forge",
  "version": "0.3.10",
  "identifier": "com.racious.mdforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MD Forge",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' tauri: asset: http://asset.localhost; connect-src 'self' https://api.github.com https://github.com; img-src 'self' tauri: asset: http://asset.localhost https: http: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "icons/json-file-icon-forge.ico": "json-file-icon-forge.ico"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown Document",
        "description": "Markdown file",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": ["json"],
        "name": "JSON Document",
        "description": "JSON data file",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/nsis-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["windows/json-file-icon.wxs"],
        "componentRefs": ["JsonFileIconRegistry"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyMUEyRTM4OTI1MDY5NTgKUldSWWFWQ1NPQzRhNHJ1d2ZRZHJ1QkNDdXJMaXZyeXBReTdLWXJsZkZ5NG0ybHZQTW9leHlmdTQK",
      "endpoints": [
        "https://github.com/Racious/MD-Forge/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
